# =============================================================
# Dockerfile.frontend
# React/Vite → Nginx static server — Multi-stage build
# =============================================================
# Stage 1: build the Vite bundle
FROM node:20-alpine AS builder

WORKDIR /app

# Install deps first (better layer caching — only re-runs when package.json changes)
COPY LGB-frontend/package.json LGB-frontend/package-lock.json ./
RUN npm ci --no-audit --prefer-offline

# Copy source and build
COPY LGB-frontend/ .
# Use production env so VITE_API_URL resolves to relative /api/v1 via nginx proxy
COPY LGB-frontend/.env.production .env
RUN npm run build

# =============================================================
# Stage 2: serve dist/ with Nginx
FROM nginx:1.27-alpine

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

# Copy our app-specific nginx config (handles /api/ proxy + SPA routing)
COPY docker/nginx/app.conf /etc/nginx/conf.d/app.conf

# Copy the built frontend
COPY --from=builder /app/dist /usr/share/nginx/html

# Health check
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD wget -qO- http://localhost/ || exit 1

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
