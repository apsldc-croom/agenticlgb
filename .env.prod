# =============================================================
# .env.prod — Production environment variables
# =============================================================
# Fill in real values before first deploy.
# Usage: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
# NEVER commit this file with real secrets to git.
# =============================================================

# Django
DJANGO_SECRET_KEY='k&-9xw7abs&e&98ihzuor(te$0%j3xdw89ox21p53x*!$-e$q('
ALLOWED_HOSTS=34.93.126.189,yourdomain.com
CORS_ALLOWED_ORIGINS=http://34.93.126.189,https://yourdomain.com

# SSL — set to true AFTER installing SSL certificate (Let's Encrypt)
SECURE_SSL=false

# PostgreSQL (runs as a Docker container on the VM)
POSTGRES_DB=agenticlgb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@db:5432/agenticlgb

# Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1