# =============================================================
# .env.prod — Production environment variables
# =============================================================
# Copy this file to .env.prod and fill in real values.
# NEVER commit this file with real secrets.
# Used with: docker compose -f docker-compose.prod.yml --env-file .env.prod up
# =============================================================

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-50-chars
ALLOWED_HOSTS=your-server-ip,yourdomain.com
CORS_ALLOWED_ORIGINS=http://yourdomain.com,https://yourdomain.com

# PostgreSQL
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# Django DATABASE_URL (auto-constructed from above in compose, but set here as fallback)
DATABASE_URL=postgres://postgres:change-me-strong-password@db:5432/postgres

# Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
